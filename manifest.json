{
  "mcpb_version": "0.1",
  "name": "audiopluginmcp",
  "version": "1.0.0",
  "description": "MCP server for audio plugin development — load VST3/AU/CLAP plugins, process audio, render MIDI, analyze spectral content, and compile JUCE projects.",
  "author": {
    "name": "PromptMonster Media Ltd",
    "url": "https://github.com/PromptMonster-Media-Ltd"
  },
  "repository": "https://github.com/PromptMonster-Media-Ltd/AudioPlugInMCP",
  "license": "MIT",
  "server": {
    "type": "node",
    "entry_point": "server/launch.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/server/launch.js"]
    }
  },
  "platforms": {
    "win32": {
      "mcp_config": {
        "command": "node.exe",
        "args": ["${__dirname}/server/launch.js"]
      }
    }
  }
}
